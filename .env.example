# Gmail OAuth client configuration
# Use either GOOGLE_CREDENTIALS_PATH or GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET.

GOOGLE_CREDENTIALS_PATH=/absolute/path/to/google-oauth-client.json
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret

# This must match an authorized redirect URI in your Google OAuth client.
GOOGLE_REDIRECT_URI=http://127.0.0.1:8765/auth/google/callback

# Local credential/token storage
GMAIL_TOKEN_PATH=/Users/your-user/.local/state/email-hoover/gmail-token.json

# Local session signing secret
SESSION_SECRET=change-me-for-non-dev-use
